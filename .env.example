# ── Telegram bot ───────────────────────────────────────────────────────────
# Token from @BotFather (/newbot). This must be a SEPARATE bot from the HA one:
# one token = one polling consumer, they can't share.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat ids allowed to talk to the bot (auth whitelist).
# Empty = allow everyone (not recommended). Send /start in the group and read
# the logged chat id, then paste it here. Usually the family group id.
TELEGRAM_ALLOWED_CHATS=

# Chat id where digests/reminders are pushed (the family group). Often the
# same value as above. Empty disables the scheduler.
TELEGRAM_NOTIFY_CHAT=

# Optional: run via webhook instead of long polling. Leave both empty for
# local dev / simple deploys (uses long polling).
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ── Gemini (natural-language parsing) ────────────────────────────────────────
GEMINI_API_KEY=
# gemini-flash-lite-latest works on your account; the exact-versioned ids 403'd.
GEMINI_MODEL=gemini-flash-lite-latest

# ── App ──────────────────────────────────────────────────────────────────────
# Timezone used to resolve "завтра/в четверг" and to place digest times.
APP_TZ=Europe/Kyiv
APP_DB=data/visits.db
ADDR=:8090

# Optional shared secret for the ICS feed (GET /calendar.ics?token=...). Empty
# = feed is open. Set it and put ?token=... in HA's Remote Calendar URL.
ICS_TOKEN=

# Optional roster to normalize the "who" field (comma-separated). Empty =
# keep person as written in the message.
VISIT_PEOPLE=

# ── Scheduler ────────────────────────────────────────────────────────────────
# Morning "today" digest time (HH:MM, in APP_TZ). Empty disables it.
DAILY_DIGEST_TIME=08:00
# Weekly "this week" digest: day-of-week (0=Sun..6=Sat) + time. Empty DOW disables.
WEEKLY_DIGEST_DOW=0
WEEKLY_DIGEST_TIME=18:00

# ── Home Assistant export (added later; leave empty for now) ─────────────────
HA_BASE_URL=
HA_TOKEN=
HA_CALENDAR_ENTITY=
